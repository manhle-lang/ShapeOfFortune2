{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      {
        "include": "cheats/cheat.json",
        "outDir": "build/src"
      }
    ],
    "watchAssets": true
  }
}
